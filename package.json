{
  "name": "sf-docs-mcp",
  "version": "1.0.0",
  "description": "MCP server that makes Salesforce documentation LLM-readable",
  "type": "module",
  "main": "dist/mcp-server.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/mcp-server.js",
    "serve": "node dist/mcp-server.js serve",
    "test-url": "node dist/test-url.js",
    "test:regression": "node dist/regression.js",
    "test:smoke": "node dist/smoke.js",
    "test:release": "npm run test:regression && npm run test:smoke"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^9.0.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.4",
    "typescript": "^5.3.0"
  }
}
